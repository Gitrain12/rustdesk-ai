# RustDesk AI Integration - Project Configuration
# Project Configuration File

PROJECT_NAME=RustDesk-AI
PROJECT_VERSION=1.0.0
PROJECT_TYPE=mobile-remote-desktop-with-ai

# Flutter Configuration
FLUTTER_VERSION=3.24+
DART_VERSION=3.0+

# Rust Configuration
RUST_VERSION=1.70+
CARGO_VERSION=1.70+

# Server Configuration
SERVER_IMAGE=rustdesk/rustdesk-server:latest
HBBS_PORT=21116
HBBR_PORT=21117

# AI Service Configuration
AI_API_VERSION=v1
AI_SERVICE_TIMEOUT=30
AI_MAX_IMAGE_SIZE=2097152
AI_OCR_LANGUAGES=eng,chi_sim,chi_tra,jpn,kor

# Mobile App Configuration
MIN_ANDROID_SDK=21
TARGET_ANDROID_SDK=34
MIN_IOS_VERSION=12.0

# Build Configuration
BUILD_OUTPUT_DIR=./build
DEBUG_KEYSTORE_PATH=./config/debug.keystore
RELEASE_KEYSTORE_PATH=./config/release.keystore

# Feature Flags
ENABLE_AI_FEATURES=true
ENABLE_OFFLINE_AI=false
ENABLE_CUSTOM_THEME=true
ENABLE_GESTURE_OPTIMIZATION=true

# Security Configuration
ENCRYPTION_ENABLED=true
ENCRYPTED_ONLY=1
USE_RELAY=N

# Development Configuration
DEV_SERVER_IP=localhost
DEV_SERVER_PORT=8080
DEV_API_URL=http://localhost:8080/api
PROD_API_URL=https://api.rustdesk-ai.com/api